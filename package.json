{
  "name": "ferns-universal-coder",
  "private": true,
  "workspaces": {
    "packages": [
      "extensions/*",
      "skills/*",
      "templates/*"
    ],
    "catalog": {
      "@mariozechner/pi-coding-agent": "^0.67.2",
      "@mariozechner/pi-ai": "^0.70.2",
      "@mariozechner/pi-tui": "^0.70.2",
      "@types/bun": "latest",
      "typescript": "^5.9.3"
    }
  },
  "type": "module",
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "check": "bun run typecheck && bun run lint && bun run format:check"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "typescript": "catalog:"
  }
}
